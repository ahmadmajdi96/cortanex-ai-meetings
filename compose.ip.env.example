# IP-only test environment for a server reachable at 135.181.40.73.
# Full camera/microphone support needs HTTPS. This uses Jitsi's self-signed
# certificate mode, so open https://135.181.40.73:8443 once and accept the
# browser warning before embedding it in the test frontend.

CONFIG=./.jitsi-meet-cfg-ip
HTTP_PORT=8080
HTTPS_PORT=8443
JVB_PORT=10000
JVB_COLIBRI_PORT=8090
TOKEN_SERVICE_PORT=3030
TOKEN_SERVICE_HOST=127.0.0.1
TEST_FRONTEND_PORT=5174
TEST_FRONTEND_HOST=0.0.0.0
JITSI_IMAGE_VERSION=stable-11031
TZ=Asia/Amman

PUBLIC_URL=https://135.181.40.73:8443
CORTANEX_APP_URL=http://135.181.40.73:5174
CORS_ALLOWED_ORIGINS=http://135.181.40.73:5174
DEFAULT_LANGUAGE=en

DISABLE_HTTPS=0
ENABLE_LETSENCRYPT=0
ENABLE_HTTP_REDIRECT=0
JVB_ADVERTISE_IPS=135.181.40.73

ENABLE_AUTH=1
ENABLE_GUESTS=0
AUTH_TYPE=jwt
JWT_APP_ID=cortanex-ai-meet
JWT_APP_SECRET=replace-this-with-openssl-rand-hex-32
JWT_ACCEPTED_ISSUERS=cortanex-ai-meet
JWT_ACCEPTED_AUDIENCES=jitsi
JWT_ALLOW_EMPTY=0
JWT_ENABLE_DOMAIN_VERIFICATION=false
JWT_TOKEN_EXP_SECONDS=7200
JITSI_TOKEN_SUB=*
JITSI_ROOM_PREFIX=cortanex-ip-test

APP_AUTH_JWT_SECRET=replace-this-with-another-openssl-rand-hex-32
ALLOW_DEMO_AUTH=1

ENABLE_AV_MODERATION=1
ENABLE_BREAKOUT_ROOMS=1
ENABLE_COLIBRI_WEBSOCKET=1
ENABLE_LOBBY=1
ENABLE_PREJOIN_PAGE=1
ENABLE_REQUIRE_DISPLAY_NAME=1
ENABLE_WELCOME_PAGE=0
ENABLE_XMPP_WEBSOCKET=1
TOOLBAR_BUTTONS=microphone,camera,closedcaptions,desktop,fullscreen,fodeviceselection,hangup,profile,chat,recording,livestreaming,etherpad,sharedvideo,settings,raisehand,videoquality,filmstrip,invite,stats,shortcuts,tileview,videobackgroundblur,download,mute-everyone,mute-video-everyone,security,participants-pane,select-background,toggle-camera,whiteboard,shareaudio,noisesuppression

JICOFO_AUTH_PASSWORD=replace-this-jicofo-password
JVB_AUTH_PASSWORD=replace-this-jvb-password
JIGASI_XMPP_PASSWORD=replace-this-jigasi-password
JIGASI_TRANSCRIBER_PASSWORD=replace-this-transcriber-password
JIBRI_RECORDER_PASSWORD=replace-this-recorder-password
JIBRI_XMPP_PASSWORD=replace-this-jibri-password
