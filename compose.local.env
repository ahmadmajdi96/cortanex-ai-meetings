# Local-only test environment for:
# docker compose --env-file compose.local.env up -d --build web prosody jicofo jvb token-service test-frontend

CONFIG=./.jitsi-meet-cfg-local
HTTP_PORT=8010
HTTPS_PORT=8444
JVB_PORT=10010
JVB_COLIBRI_PORT=8090
TOKEN_SERVICE_PORT=3030
TEST_FRONTEND_PORT=5174
JITSI_IMAGE_VERSION=stable-11031
TZ=Asia/Amman

PUBLIC_URL=http://localhost:8010
CORTANEX_APP_URL=http://localhost:5174
CORS_ALLOWED_ORIGINS=http://localhost:5174
DEFAULT_LANGUAGE=en

DISABLE_HTTPS=1
ENABLE_LETSENCRYPT=0
ENABLE_HTTP_REDIRECT=0

ENABLE_AUTH=1
ENABLE_GUESTS=0
AUTH_TYPE=jwt
JWT_APP_ID=cortanex-ai-meet
JWT_APP_SECRET=local-dev-jitsi-secret-change-me
JWT_ACCEPTED_ISSUERS=cortanex-ai-meet
JWT_ACCEPTED_AUDIENCES=jitsi
JWT_ALLOW_EMPTY=0
JWT_ENABLE_DOMAIN_VERIFICATION=false
JWT_TOKEN_EXP_SECONDS=7200
JITSI_TOKEN_SUB=*
JITSI_ROOM_PREFIX=cortanex-test

APP_AUTH_JWT_SECRET=local-dev-app-secret-change-me
ALLOW_DEMO_AUTH=1

ENABLE_AV_MODERATION=1
ENABLE_BREAKOUT_ROOMS=1
ENABLE_COLIBRI_WEBSOCKET=1
ENABLE_LOBBY=1
ENABLE_PREJOIN_PAGE=1
ENABLE_REQUIRE_DISPLAY_NAME=1
ENABLE_WELCOME_PAGE=0
ENABLE_XMPP_WEBSOCKET=1
TOOLBAR_BUTTONS=microphone,camera,closedcaptions,desktop,fullscreen,fodeviceselection,hangup,profile,chat,recording,livestreaming,etherpad,sharedvideo,settings,raisehand,videoquality,filmstrip,invite,stats,shortcuts,tileview,videobackgroundblur,download,mute-everyone,mute-video-everyone,security,participants-pane,select-background,toggle-camera,whiteboard,shareaudio,noisesuppression

JICOFO_AUTH_PASSWORD=local-jicofo-password
JVB_AUTH_PASSWORD=local-jvb-password
JIGASI_XMPP_PASSWORD=local-jigasi-password
JIGASI_TRANSCRIBER_PASSWORD=local-transcriber-password
JIBRI_RECORDER_PASSWORD=local-recorder-password
JIBRI_XMPP_PASSWORD=local-jibri-password
