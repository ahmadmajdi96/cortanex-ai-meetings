# Copy to .env for production and rotate every secret before exposing the stack.
COMPOSE_PROJECT_NAME=mohkam-rag

# Public ports
GATEWAY_PORT=5001
MINIO_CONSOLE_PORT=9001
PROMETHEUS_PORT=9090
GRAFANA_PORT=3001

# Core secrets
RAG_API_KEYS=change-me-rag-api-key
POSTGRES_DB=rag
POSTGRES_USER=rag
POSTGRES_PASSWORD=change-me-postgres-password
REDIS_PASSWORD=change-me-redis-password
MINIO_ROOT_USER=ragadmin
MINIO_ROOT_PASSWORD=change-me-minio-password
QDRANT_API_KEY=change-me-qdrant-api-key
GRAFANA_ADMIN_PASSWORD=change-me-grafana-password

# RAG behavior
RAG_DEFAULT_TENANT=default
RAG_ALLOWED_ORIGINS=*
RAG_COLLECTION=rag_chunks
RAG_MAX_UPLOAD_MB=250
RAG_CHUNK_TOKENS=750
RAG_CHUNK_OVERLAP_TOKENS=120
RAG_TOP_K=24
RAG_RERANK_TOP_N=8
RAG_SCORE_THRESHOLD=0.15
RAG_QUERY_TIMEOUT_SECONDS=180

# Retrieval model server. BGE-M3 is multilingual and works well for Arabic/English legal corpora.
EMBEDDING_MODEL=BAAI/bge-m3
EMBEDDING_DIM=1024
RERANKER_MODEL=BAAI/bge-reranker-v2-m3
RETRIEVAL_DEVICE=cuda
RETRIEVAL_BATCH_SIZE=12
RETRIEVAL_MAX_LENGTH=8192
RETRIEVAL_USE_FP16=true

# vLLM. Defaults target a single RTX 4090. Lower LLM_GPU_MEMORY_UTILIZATION or
# LLM_MAX_MODEL_LEN if you see CUDA OOM during startup.
HF_TOKEN=
VLLM_IMAGE_TAG=latest
LLM_MODEL=Qwen/Qwen3-14B-AWQ
LLM_SERVED_MODEL_NAME=local-rag-llm
LLM_MAX_MODEL_LEN=16384
LLM_GPU_MEMORY_UTILIZATION=0.74
LLM_MAX_NUM_SEQS=8
LLM_DTYPE=auto

# API runtime
API_WORKERS=2
WORKER_CONCURRENCY=1
